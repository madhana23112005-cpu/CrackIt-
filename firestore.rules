rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Default-Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global security helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Enforce valid user profiles structure
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.name is string &&
             data.name.size() <= 150 &&
             data.role in ['student', 'tpo', 'superadmin'];
    }

    // Secure user profiles collection
    match /users/{userId} {
      // Users can read their own profile, or let authenticated TPO/Admins view profiles
      allow read: if isOwner(userId) || (isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['tpo', 'superadmin']
      ));

      // Standard user profiles are restricted to the owner
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        // Protect roles from self-escalation unless promo is verified or requested
        request.resource.data.role == resource.data.role ||
        resource.data.role == 'superadmin' ||
        request.auth.token.email_verified == true
      );
      
      // Delete operations are completely blocked by default for enterprise safety
      allow delete: if false;
    }
  }
}
